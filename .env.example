# Mattermost
MM_BOT_TOKEN=токен_бота_mattermost
MM_BASE_URL=https://mm.example.com

# OpenRouter модель (например: z-ai/glm-4.7, openai/gpt-4o, anthropic/claude-3.5-sonnet)
LLM_MODEL=z-ai/glm-4.7

# OpenRouter API ключ — для модели и для web search (Perplexity)
OPENROUTER_API_KEY=sk-or-v1-...

# Email (IMAP/SMTP через himalaya)
EMAIL_ADDRESS=bot@example.com
EMAIL_PASSWORD=app_password
IMAP_HOST=imap.example.com
SMTP_HOST=smtp.example.com

# Администратор: имя (для USER.md) и логин MM
ADMIN_NAME=Иван Иванов
ADMIN_USERNAME=username1

# Dashboard — пароль и публичный Origin (без слэша в конце), иначе «origin not allowed»
# Пример за nginx: http://46.243.142.210  или https://bot.example.com
GATEWAY_PASSWORD=changeme
PUBLIC_ORIGIN=http://127.0.0.1:18789

# Dashboard по HTTP с публичного IP: браузер требует secure context. Временно: true (слабее pairing).
# В проде: HTTPS + PUBLIC_ORIGIN=https://your.domain и оставь false
CONTROL_UI_DISABLE_DEVICE_AUTH=false

# gog (Google Workspace CLI)
GOG_KEYRING_PASSWORD=changeme
GOG_ACCOUNT=you@gmail.com

# Corp Atlassian — скилл atlassian читает эти переменные напрямую
# Jira PAT:        https://tasks.sberdevices.ru/secure/ViewProfile.jspa
# Confluence PAT:  https://confluence.sberdevices.ru/plugins/personalaccesstokens/usertokens.action
JIRA_URL=https://tasks.sberdevices.ru
JIRA_PAT_TOKEN=
JIRA_SSL_VERIFY=true
CONFLUENCE_URL=https://confluence.sberdevices.ru
CONFLUENCE_PAT_TOKEN=
CONFLUENCE_SSL_VERIFY=true

# Corp GitLab — скилл glab читает эти переменные напрямую
# GitLab PAT:      https://git.sberdevices.ru/-/user_settings/personal_access_tokens (scopes: read_api, read_repository [+ api для записи])
GITLAB_HOST=git.sberdevices.ru
GITLAB_TOKEN=
