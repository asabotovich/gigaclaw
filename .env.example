# Mattermost
# Бот-токен всё ещё нужен: скрипты внутри контейнера (BOOT.md, AGENTS.md,
# skills/mattermost/SKILL.md) дергают MM REST напрямую (get user id, read
# thread history и т.п.). WS-подключение из контейнера отключено — входящие
# доставляет оркестратор через /v1/responses.
MM_BOT_TOKEN=токен_бота_mattermost
MM_BASE_URL=https://mm.example.com

# gigaclaw-orchestrator — outbound-доставка (cron/push от контейнера в MM).
# URL указывает на push-endpoint оркестратора снаружи контейнера.
# На Docker Desktop (Mac/Windows) host.docker.internal резолвится в хост.
# На Linux оркестратор должен передавать контейнерам
# --add-host=host.docker.internal:host-gateway (или заменить на IP хоста).
ORCHESTRATOR_URL=http://host.docker.internal:18790
ORCHESTRATOR_PUSH_SECRET=

# OpenRouter модель (например: z-ai/glm-4.7, openai/gpt-4o, anthropic/claude-3.5-sonnet)
LLM_MODEL=z-ai/glm-4.7

# Vision-модель для разбора картинок/скриншотов (OCR, UI, диаграммы).
# Дефолт — Qwen3-VL-235B-A22B Instruct (non-thinking, content всегда первым).
# Альтернативы: qwen/qwen3-vl-32b-instruct (дешевле), nvidia/nemotron-nano-12b-v2-vl:free.
# НЕ использовать z-ai/glm-4.6v — thinking-модель, content нередко пустой.
LLM_VISION_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# OpenRouter API ключ — для модели и для web search (Perplexity)
OPENROUTER_API_KEY=sk-or-v1-...

# Email (IMAP/SMTP через himalaya)
EMAIL_ADDRESS=bot@example.com
EMAIL_PASSWORD=app_password
IMAP_HOST=imap.example.com
SMTP_HOST=smtp.example.com

# Администратор: имя (для USER.md) и логин MM
ADMIN_NAME=Иван Иванов
ADMIN_USERNAME=username1

# Dashboard auth (OpenClaw Control UI / WebSocket Gateway) — токен-only.
# Сгенерить: openssl rand -hex 32
# Вставить в поле "Gateway Token" в браузере. Или открыть
#   http://127.0.0.1:<port>/?token=<этот_токен>
# и забукмаркать — тогда вводить вообще не надо.
OPENCLAW_GATEWAY_TOKEN=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# Публичный Origin (без слэша в конце) — откуда браузер будет коннектиться.
# Локально: http://127.0.0.1:18789
# За nginx/прокси: http://46.243.142.210  или  https://bot.example.com
PUBLIC_ORIGIN=http://127.0.0.1:18789

# Dashboard по HTTP с публичного IP: браузер требует secure context. Временно: true (слабее pairing).
# Локально (127.0.0.1) и HTTPS — false.
CONTROL_UI_DISABLE_DEVICE_AUTH=false

# gog (Google Workspace CLI)
GOG_KEYRING_PASSWORD=changeme
GOG_ACCOUNT=you@gmail.com

# Corp Atlassian — скилл atlassian читает эти переменные напрямую
# Jira PAT:        https://tasks.sberdevices.ru/secure/ViewProfile.jspa
# Confluence PAT:  https://confluence.sberdevices.ru/plugins/personalaccesstokens/usertokens.action
JIRA_URL=https://tasks.sberdevices.ru
JIRA_PAT_TOKEN=
JIRA_SSL_VERIFY=true
CONFLUENCE_URL=https://confluence.sberdevices.ru
CONFLUENCE_PAT_TOKEN=
CONFLUENCE_SSL_VERIFY=true

# Corp GitLab — скилл glab читает эти переменные напрямую
# GitLab PAT:      https://git.sberdevices.ru/-/user_settings/personal_access_tokens (scopes: read_api, read_repository [+ api для записи])
GITLAB_HOST=git.sberdevices.ru
GITLAB_TOKEN=
