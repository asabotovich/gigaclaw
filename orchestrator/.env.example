# clawfarm CLI config — copy to orchestrator/.env and tweak.
# These vars are read by the CLI itself (not passed to the bot container).

# Docker image tag (must exist locally or in a configured registry)
# GIGACLAW_IMAGE=gigaclaw:latest

# Host directory where per-user data is stored.
# Linux/prod default: /data/users. On macOS Docker Desktop, /data is not shared —
# use a path inside $HOME:
GIGACLAW_DATA_ROOT=/Users/$USER/gigaclaw-data

# Starting port; CLI picks the first free port starting from here.
# GIGACLAW_BASE_PORT=18789
