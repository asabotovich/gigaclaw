#compdef clawfarm
# Zsh completion for clawfarm.
# Install: add the directory containing this file to your fpath, e.g.
#   echo 'fpath=(/path/to/gigaclaw/orchestrator/completions $fpath)' >> ~/.zshrc
#   echo 'autoload -Uz compinit && compinit' >> ~/.zshrc
# Then: source ~/.zshrc

_clawfarm() {
  local -a subcommands
  subcommands=(
    'add-user:Provision + create + start bot for user'
    'remove:Stop and remove user container (data kept on disk)'
    'reset:Recreate container (keeps data volume)'
    'stop:Stop running container'
    'start:Start stopped container'
    'logs:Show container logs'
    'list:List all GigaClaw-managed containers'
    'help:Display help for command'
  )

  # Pull live usernames from docker labels
  local -a users
  users=(${(f)"$(docker ps -a --filter label=gigaclaw.user --format '{{.Label "gigaclaw.user"}}' 2>/dev/null)"})

  _arguments -C \
    '1: :->subcmd' \
    '*:: :->args'

  case $state in
    subcmd)
      _describe 'command' subcommands
      ;;
    args)
      case $words[1] in
        add-user|reset)
          _arguments \
            '1:username:' \
            '(-e --env)'{-e,--env}'[Path to .env file]:env file:_files -g "*.env*"'
          ;;
        remove|stop|start|logs)
          if (( CURRENT == 2 )); then
            if (( ${#users[@]} )); then
              _describe 'username' users
            else
              _message 'username (no running GigaClaw containers found)'
            fi
          elif [[ $words[1] == logs ]]; then
            _arguments \
              '(-n --tail)'{-n,--tail}'[Number of lines]:n:' \
              '(-f --follow)'{-f,--follow}'[Follow output]'
          fi
          ;;
      esac
      ;;
  esac
}

_clawfarm "$@"
